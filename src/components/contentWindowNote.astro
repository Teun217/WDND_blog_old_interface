---
import { Marked } from 'marked';

const md = new Marked({
    breaks: true,
    renderer: {
        html({ text }: { text: string }) {
            return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }
    }
});

interface Props {
    id: string;
    title: string;
    note: string;
}
const { id, title, note } = Astro.props;
const renderedNote = md.parse(note) as string;
---

<section data-component="content-window-note" id={`${id}-note`} style="display:none">
    <div class="controls">
        <button class="close-btn">✕</button>
    </div>
    <h2>{title}.note</h2>
    <div class="note-content" set:html={renderedNote} />
</section>

<style>
    :root {
        --box-shadow-size: 2px;
        --frame-margin: 1em;
    }

    section {
        position: absolute;
        background-color: rgb(210, 207, 199);
        resize: both;
        min-width: 450px;
        min-height: fit-content;
        height: 60dvh;
        max-height: 100dvh;
        width: 20em;
        overflow: auto;
        display: grid;
        grid-template-rows: auto 1fr;
        z-index: 1;

        box-shadow:
            inset var(--box-shadow-size) var(--box-shadow-size) rgba(255, 255, 255, 0.75),
            inset calc(-1 * var(--box-shadow-size)) calc(-1 * var(--box-shadow-size)) rgba(0, 0, 0, 0.75);
    }

    h2 {
        margin: 5px;
        padding: 5px;
        padding-right: 3em;
        background-color: rgb(17, 13, 141);
        color: white;
    }

    .note-content {
        margin: var(--frame-margin);
        padding: 0.5em;
        background-color: white;
        box-sizing: border-box;
        box-shadow:
            inset var(--box-shadow-size) var(--box-shadow-size) rgba(0, 0, 0, 0.75),
            inset calc(-1 * var(--box-shadow-size)) calc(-1 * var(--box-shadow-size)) rgba(255, 255, 255, 0.75);
    }

    :global(.note-content p) {
        margin: 0 0 0.75em;
        overflow-wrap: break-word;
    }

    :global(.note-content p:last-child) {
        margin-bottom: 0;
    }

    .controls {
        position: absolute;
        right: 0;
        top: 0;
        padding: 1em;
        display: flex;
        gap: 0.5em;

        button {
            height: 1.25em;
            width: 1.25em;
            border: none;
            font-size: 1em;
            font-weight: bold;
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: inherit;
            background-color: rgb(193, 193, 193);
            box-shadow:
                inset var(--box-shadow-size) var(--box-shadow-size) rgba(255, 255, 255, 0.75),
                inset calc(-1 * var(--box-shadow-size)) calc(-1 * var(--box-shadow-size)) rgba(0, 0, 0, 0.75);
            &:hover {
                background-color: red;
                color: white;
            }
        }
    }
</style>

<script>
    declare global { interface Window { __zTop: number } }
    window.__zTop ??= 10;

    document.querySelectorAll<HTMLElement>('section[data-component="content-window-note"]').forEach(win => {
        const handle = win.querySelector('h2') as HTMLElement;
        const closeBtn = win.querySelector('.close-btn') as HTMLElement;

        handle.style.cursor = 'grab';

        win.addEventListener('mousedown', () => { win.style.zIndex = String(++window.__zTop); });
        closeBtn.addEventListener('click', () => { win.style.display = 'none'; });

        handle.addEventListener('mousedown', (e: MouseEvent) => {
            const rect = win.getBoundingClientRect();
            const offsetX = e.clientX - rect.left;
            const offsetY = e.clientY - rect.top;
            handle.style.cursor = 'grabbing';
            document.body.style.userSelect = 'none';

            function onMouseMove(e: MouseEvent) {
                const x = Math.min(Math.max(0, e.clientX - offsetX), Math.max(0, window.innerWidth - win.offsetWidth));
                const y = Math.min(Math.max(0, e.clientY - offsetY), Math.max(0, window.innerHeight - win.offsetHeight));
                win.style.left = `${x}px`;
                win.style.top = `${y}px`;
            }

            function onMouseUp() {
                handle.style.cursor = 'grab';
                document.body.style.userSelect = '';
                document.removeEventListener('mousemove', onMouseMove);
                document.removeEventListener('mouseup', onMouseUp);
            }

            document.addEventListener('mousemove', onMouseMove);
            document.addEventListener('mouseup', onMouseUp);
        });
    });
</script>
