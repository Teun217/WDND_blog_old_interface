---
import { md } from '../utils/markdown';

interface Props {
    id: string;
    title: string;
    note: string;
}
const { id, title, note } = Astro.props;
const renderedNote = md.parse(note) as string;
---

<section data-component="content-window-note" id={`${id}-note`} style="display:none">
    <div class="controls">
        <button class="close-btn">✕</button>
    </div>
    <h2>{title}.note</h2>
    <div class="note-content" set:html={renderedNote} />
</section>

<style>
    section {
        position: absolute;
        background-color: rgb(210, 207, 199);
        resize: both;
        min-width: 450px;
        min-height: fit-content;
        height: 60dvh;
        max-height: 100dvh;
        width: 20em;
        overflow: auto;
        display: grid;
        grid-template-rows: auto 1fr;
        z-index: 1;

        box-shadow:
            inset var(--box-shadow-size) var(--box-shadow-size) rgba(255, 255, 255, 0.75),
            inset calc(-1 * var(--box-shadow-size)) calc(-1 * var(--box-shadow-size)) rgba(0, 0, 0, 0.75);
    }

    h2 {
        margin: 5px;
        padding: 5px;
        padding-right: 3em;
        background-color: rgb(17, 13, 141);
        color: white;
    }

    .note-content {
        margin: var(--frame-margin);
        padding: 0.5em;
        background-color: white;
        box-sizing: border-box;
        box-shadow:
            inset var(--box-shadow-size) var(--box-shadow-size) rgba(0, 0, 0, 0.75),
            inset calc(-1 * var(--box-shadow-size)) calc(-1 * var(--box-shadow-size)) rgba(255, 255, 255, 0.75);
    }

    :global(.note-content p) {
        margin: 0 0 0.75em;
        overflow-wrap: break-word;
    }

    :global(.note-content p:last-child) {
        margin-bottom: 0;
    }

    .controls {
        position: absolute;
        right: 0;
        top: 0;
        padding: 1em;
        display: flex;
        gap: 0.5em;

        button {
            height: 1.25em;
            width: 1.25em;
            border: none;
            font-size: 1em;
            font-weight: bold;
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: inherit;
            background-color: rgb(193, 193, 193);
            box-shadow:
                inset var(--box-shadow-size) var(--box-shadow-size) rgba(255, 255, 255, 0.75),
                inset calc(-1 * var(--box-shadow-size)) calc(-1 * var(--box-shadow-size)) rgba(0, 0, 0, 0.75);
            &:hover {
                background-color: red;
                color: white;
            }
        }
    }
</style>

<script>
    import { bringToFront, makeDraggable } from '../scripts/windowUtils';

    document.querySelectorAll<HTMLElement>('section[data-component="content-window-note"]').forEach(win => {
        const handle = win.querySelector('h2') as HTMLElement;
        const closeBtn = win.querySelector('.close-btn') as HTMLElement;

        win.addEventListener('mousedown', () => bringToFront(win));
        closeBtn.addEventListener('click', () => { win.style.display = 'none'; });

        makeDraggable(win, handle);
    });
</script>
