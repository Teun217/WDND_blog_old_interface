---
import type { Item } from '../data/items';

interface Props {
    windowId: string;
    title: string;
    items: Item[];
}
const { windowId, title, items } = Astro.props;

const categories = [...new Set(items.map(p => p.category))];
const toClass = (cat: string) => `category-${cat.replace(/[^a-zA-Z0-9]/g, '_')}`;
const dynamicCSS = categories.map(cat => {
    const cls = toClass(cat);
    return `section[data-window-id="${windowId}"] .categories:has(li.${cls} input:checked) ~ .projects > li.${cls} { display: block; }`;
}).join('\n');
---

<section data-window-id={windowId} style="display:none">
    <div class="buttons">
        <button class="close-btn">✕</button>
    </div>
    <h2>{title}</h2>
    <div class="project-window-ui">
        <ul class="categories">
            {categories.map(category => (
                <li class={toClass(category)}>
                    <label>
                        <input type="radio" name={`category-${windowId}`} value={category} />
                        <span class="icon">📁</span><span class="label-text">{category}</span>
                    </label>
                </li>
            ))}
        </ul>
        <ul class="projects">
            {items.map(p => (
                <li class={toClass(p.category)}>
                    <button data-project-id={p.id}>
                        <span class="title">{p.title}</span><span class="date">{p.date}</span>
                    </button>
                </li>
            ))}
        </ul>
    </div>
</section>

<Fragment set:html={`<style>${dynamicCSS}</style>`} />

<style>
    section {
        position: absolute;
        background-color: rgb(210, 207, 199);
        resize: both;
        min-width: 500px;
        min-height: 300px;
        width: 30em;
        overflow: auto;
        display: grid;
        grid-template-rows: auto 1fr;
        z-index: 1;

        box-shadow:
            inset var(--box-shadow-size) var(--box-shadow-size) rgba(255, 255, 255, 0.75),
            inset calc(-1 * var(--box-shadow-size)) calc(-1 * var(--box-shadow-size)) rgba(0, 0, 0, 0.75);
    }
    .buttons {
        position: absolute;
        right: 0;
        top: 0;
        padding: 1em;
        display: flex;
        gap: 0.5em;

        button {
            height: 1.25em;
            width: 1.25em;
            border: none;
            font-size: 1em;
            font-weight: bold;
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            box-shadow:
                inset var(--box-shadow-size) var(--box-shadow-size) rgba(255, 255, 255, 0.75),
                inset calc(-1 * var(--box-shadow-size)) calc(-1 * var(--box-shadow-size)) rgba(0, 0, 0, 0.75);
            &:hover {
                background-color: red;
                color: white;
            }
        }
    }
    h2 {
        margin: 5px;
        padding: 5px;
        padding-right: 3em;

        background-color: rgb(17, 13, 141);
        color: white;
    }

    ul {
        margin: 0;
        padding: 0;
    }
    li {
        list-style-type: none;
        display: block;
    }

    .projects > li {
        display: none;
    }

    .project-window-ui {
        display: grid;
        grid-template-columns: auto 1em 1fr;
        background-color: white;
        margin: 0.5em;
        box-shadow:
            inset var(--box-shadow-size) var(--box-shadow-size) rgba(0, 0, 0, 0.75),
            inset calc(-1 * var(--box-shadow-size)) calc(-1 * var(--box-shadow-size)) rgba(255, 255, 255, 0.75);
        label:hover .label-text {
            text-decoration: underline;
        }
    }

    .project-window-ui::after {
        content: "";
        grid-column: 2;
        grid-row: 1;
        width: 100%;
        height: 100%;
        background-color: rgb(210, 207, 199);
        box-shadow:
            inset var(--box-shadow-size) 0 rgba(255, 255, 255, 0.75),
            inset calc(-1 * var(--box-shadow-size)) 0 rgba(0, 0, 0, 0.75);
    }

    .categories {
        margin: 0.5em;
        margin-right: 1em;
        input {
            display: none;
        }
        .icon {
            margin-right: 0.25em;
        }
    }

    .projects {
        margin: 0.5em;
        grid-column: 3;
        overflow: hidden;
        button {
            border: 0;
            background: none;
            font-size: 1em;
            padding: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            gap: 1em;
            overflow: hidden;
            &:hover {
                text-decoration: underline;
            }
            .title {
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
                min-width: 0;
                text-align: left;
            }
            .date {
                color: gray;
                white-space: nowrap;
                flex-shrink: 0;
            }
        }
    }
</style>

<script>
    import '../scripts/initWindows';

    document.querySelectorAll<HTMLElement>('button[data-project-id]').forEach(btn => {
        btn.addEventListener('click', () => {
            const win = document.getElementById(btn.dataset.projectId!);
            if (win) {
                win.style.display = 'grid';
                win.style.zIndex = String(++window.__zTop);
                if (!win.style.left) {
                    const offset = (window.__zTop - 10) * 30;
                    const maxX = Math.max(0, window.innerWidth - win.offsetWidth);
                    const maxY = Math.max(0, window.innerHeight - win.offsetHeight);
                    win.style.left = `${Math.min(offset, maxX)}px`;
                    win.style.top = `${Math.min(offset, maxY)}px`;
                }
            }
        });
    });
</script>
